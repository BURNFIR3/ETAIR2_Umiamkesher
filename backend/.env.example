# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://etair:etair_secret@localhost:5432/etair
CELERY_DATABASE_URL=postgresql+psycopg2://etair:etair_secret@localhost:5432/etair

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MinIO (File Storage) ─────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=etair_minio
MINIO_SECRET_KEY=etair_minio_secret
MINIO_BUCKET_FILES=etair-files
MINIO_BUCKET_THUMBS=etair-thumbnails
MINIO_SECURE=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
# CHANGE THIS IN PRODUCTION — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_in_production_super_secret_key

# ─── Groq (Primary LLM — free tier) ─────────────────────────────────────────
# Required for: AI Query answering (query.py), SOPRAG RCA Agent (rca_agent.py)
# Get your free API key at: https://console.groq.com
# Recommended model: llama-3.3-70b-versatile (free, no billing required)
# Upgrade options: deepseek-r1-distill-llama-70b (stronger reasoning, still free)
GROQ_API_KEY=""

# Model used for the main Q&A query endpoint
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Model used for the SOPRAG RCA Agent (Feature 3) — can differ from chat model
# Recommend a reasoning-capable model for better RCA quality:
#   deepseek-r1-distill-llama-70b  (best reasoning, free)
#   llama-3.3-70b-versatile        (faster, solid quality)
GROQ_RCA_MODEL=llama-3.3-70b-versatile

# ─── OpenAI (Embeddings only — optional) ──────────────────────────────────────
# Required for: vector/semantic search, compliance namespace search in RCA agent
# If not set, only keyword search works (vector search is skipped gracefully)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Embedding model to use (text-embedding-3-small is cheapest and works well)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
